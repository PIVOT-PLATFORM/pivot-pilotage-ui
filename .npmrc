# GitHub Packages — @pivot-platform scoped packages require authentication.
# In CI, NODE_AUTH_TOKEN is provided to `npm publish` (release.yml) via secrets.GITHUB_TOKEN.
# Locally: export NODE_AUTH_TOKEN=<your GitHub PAT with read:packages scope>
@pivot-platform:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
